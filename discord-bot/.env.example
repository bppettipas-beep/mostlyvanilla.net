# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your Discord server (guild) ID — right-click the server → Copy Server ID
GUILD_ID=your_guild_id_here

# Shared secret between the bot API and the Minecraft plugin — make up any random string
API_SECRET=change_me

# Port the bot's HTTP API listens on (default 3000)
# PORT=3000
