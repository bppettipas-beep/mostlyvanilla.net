# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your Discord server (guild) ID — right-click the server → Copy Server ID
GUILD_ID=your_guild_id_here

# The "Verified" role ID to grant — right-click the role → Copy Role ID
VERIFIED_ROLE_ID=your_verified_role_id_here

# Secret shared with the Minecraft plugin — change this to something random
API_SECRET=change-me-to-something-random

# Port the HTTP server listens on (Minecraft plugin calls this)
API_PORT=3000

# How long codes are valid (minutes)
CODE_EXPIRY_MINUTES=10

# Channel ID where the bot posts verification prompts when someone joins
# Right-click your #verify channel → Copy Channel ID
VERIFY_CHANNEL_ID=your_verify_channel_id_here

# Channel ID used to generate invite links (can be the same as VERIFY_CHANNEL_ID)
# Invites are single-use and expire with the code
INVITE_CHANNEL_ID=your_invite_channel_id_here

# Minutes a new member has to verify before being kicked (0 to disable)
KICK_TIMEOUT_MINUTES=15
